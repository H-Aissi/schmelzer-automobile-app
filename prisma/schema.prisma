generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

model Car {
  id             String       @id @default(cuid())
  title          String
  make           String
  makeNormalized String
  model          String
  year           Int
  price          Int
  mileage        Int
  fuelType       FuelType
  transmission   Transmission
  power          Int
  color          String
  description    String
  status         CarStatus    @default(ACTIVE)
  images         Image[]
  offers         Offer[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([status])
  @@index([makeNormalized])
  @@index([createdAt])
}

model Image {
  id        String   @id @default(cuid())
  carId     String
  car       Car      @relation(fields: [carId], references: [id], onDelete: Cascade)
  url       String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@index([carId])
  @@index([carId, sortOrder])
}

model Offer {
  id          String      @id @default(cuid())
  carId       String
  car         Car         @relation(fields: [carId], references: [id], onDelete: Cascade)
  firstName   String
  lastName    String
  email       String
  phone       String?
  offerAmount Int
  message     String?
  status      OfferStatus @default(NEW)
  createdAt   DateTime    @default(now())

  @@index([carId])
  @@index([status])
  @@index([createdAt])
}

enum FuelType {
  BENZIN
  DIESEL
  ELEKTRO
  HYBRID
  GAS
}

enum Transmission {
  MANUELL
  AUTOMATIK
}

enum CarStatus {
  ACTIVE
  SOLD
  HIDDEN
}

enum OfferStatus {
  NEW
  READ
  CONTACTED
  DECLINED
}
