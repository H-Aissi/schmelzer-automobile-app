# Datenbankverbindung (PostgreSQL)
# Beispiel: postgresql://user:password@host:5432/dbname
DATABASE_URL=

# JWT-Secret (min. 32 Zeichen) — generieren: openssl rand -base64 32
JWT_SECRET=

# Resend E-Mail-Versand
RESEND_API_KEY=
FROM_EMAIL=noreply@schmelzerautomobile.de
OWNER_EMAIL=inhaber@schmelzerautomobile.de

# Öffentliche URLs (kein trailing slash)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_ADMIN_URL=http://localhost:3000

# Einmalig für prisma db seed — danach aus .env.local entfernen
SEED_ADMIN_EMAIL=admin@schmelzerautomobile.de
SEED_ADMIN_PASSWORD=
